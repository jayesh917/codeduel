# The port the server will run on
PORT=3000

# The URL where the frontend is hosted. Used for configuring CORS.
# For local development, this is typically http://localhost:3000
FRONTEND_URL=http://localhost:3000

# The URL of the backend API for the frontend to communicate with
# Leave blank to use relative paths (which works when served together)
VITE_API_URL=http://localhost:8000
